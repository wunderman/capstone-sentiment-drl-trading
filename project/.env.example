# ============================================
# Copy to .env and fill in real keys.
# .env is gitignored; .env.example is committed.
# ============================================

# ---- REQUIRED for LangGraph trade-generation pipeline ----
# Used by Capstone/graph/trade_generation_pipeline.py (gpt-4o-mini via OpenRouter)
OPENROUTER_API_KEY=

# ---- REQUIRED for Alpha Vantage live NEWS_SENTIMENT ----
# Free tier: 25 calls/day. Used by pipeline.fetch_alphavantage_live_sentiment
# and Capstone/agents/analysts/sentiment_analyst.py
# Get from https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# ---- REQUIRED for Apify multi-platform scraping ----
# Used by pipeline.fetch_apify_social_sentiment
# Get from https://console.apify.com/account/integrations
APIFY_API_KEY=

# ---- OPTIONAL pipeline toggles (default off) ----
# USE_LIVE_ALPHAVANTAGE=1   # fetch live AV news per ticker in pipeline.py
# USE_APIFY=1               # run Apify scrape in pipeline.py
# USE_APIFY_TWITTER=1       # include Twitter/X in Apify (expensive)

# ---- TIER 1 social collectors (older, optional) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StockSentimentAgent/1.0
STOCKTWITS_API_TOKEN=

# ---- TIER 2 social collectors (older, optional) ----
YOUTUBE_API_KEY=
BLUESKY_HANDLE=
BLUESKY_PASSWORD=

# ---- TIER 3 (paid, optional) ----
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
