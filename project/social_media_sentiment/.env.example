# ============================================
# TIER 1 SOURCES (Build First)
# ============================================

# Reddit API (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=StockSentimentAgent/1.0

# StockTwits API (OPTIONAL - public data works without auth)
# Get from https://api.stocktwits.com/developers
STOCKTWITS_API_TOKEN=your_stocktwits_token_optional

# Telegram (No API key needed for web scraping)
# Scrapes public channels via https://t.me/s/CHANNEL_NAME

# ============================================
# TIER 2 SOURCES (Add for Diversity)
# ============================================

# YouTube Data API v3 (get from https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key

# Bluesky (OPTIONAL - public data works without auth)
# Better access with account: https://bsky.app/
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_PASSWORD=your_password

# ============================================
# TIER 3 SOURCES (Only if budget allows)
# ============================================

# Twitter/X API (get from https://developer.twitter.com/)
# Cost: $100/month for basic tier
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
